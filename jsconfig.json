{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"]
}
